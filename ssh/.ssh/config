Host lab
  HostName 10.123.0.2
  User ak
  ForwardAgent yes
  RemoteForward /run/user/1000/gnupg/S.gpg-agent /Users/ak/.gnupg/S.gpg-agent.extra

Host pug
  Hostname 10.123.0.3
  User ak
  ForwardAgent yes

Host box
  Hostname 10.123.0.5
  User ak

Host bunk
  Hostname 10.123.57.3
  User ak

Host fox
  Hostname fox.fahm.fr
  User ak

Host *
  # Ensure KnownHosts are unreadable if leaked - it is otherwise easier to know which hosts your keys have access to.
  HashKnownHosts yes

  ControlPath ~/.ssh/.controlmaster-%C
  ControlPersist 10m
  ControlMaster auto
  AddKeysToAgent yes
  ServerAliveInterval 30
  ConnectTimeout 5

  # IPv4 only for speed
  AddressFamily inet
  Compression yes

# Crypto algorithms intentionally left unset: modern OpenSSH defaults are strong and
# keep pace with upstream, unlike a pinned list that would freeze out future ciphers.

# Drop-in host configs last so the explicit Host blocks above win on first-match.
Include config.d/*
