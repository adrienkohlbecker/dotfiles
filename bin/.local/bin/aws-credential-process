#!/usr/bin/env bash
set -euo pipefail

# aws-cli credential_process: emit MFA-backed temporary STS credentials.
#
# The long-term IAM key + MFA OTP live in 1Password and are used only to call
# sts:GetSessionToken. The AWS CLI does NOT cache credential_process output
# across invocations, so this script caches the STS *session* itself in the
# macOS login keychain (encrypted at rest) and re-emits it while it still has a
# healthy runway — otherwise every aws command would re-run op + MFA + STS. Only
# the temporary session (valid up to the duration below) is cached, never the
# long-term key. The keychain item's ACL is scoped to /usr/bin/security so reads
# don't pop an access-confirmation dialog.
#
# Consumers cache credential_process output in memory for their whole lifetime:
# the aws-sdk-go-v2 provider behind tofu reads creds once at startup and won't
# re-invoke this script if they expire mid-apply. Handing out a session with only
# a few minutes left therefore blows up a long run with UnrecognizedClientException
# ("security token invalid"). So re-mint proactively once less than min_lifetime
# remains, guaranteeing every invocation starts with a generous runway. A fresh
# session is always the full duration, so this re-mints roughly once per duration
# regardless — just sooner — and the OTP is read non-interactively from 1Password.
#
# Wired from ~/.aws/config: credential_process = /Users/ak/.local/bin/aws-credential-process

mfa_serial="arn:aws:iam::000390721279:mfa/ak"
op_item="op://Private/u3dlfqopqvanpp7vy3gai2sy4y"
duration=129600   # 36h — the GetSessionToken maximum for IAM-user credentials
margin=300        # set not_after this many seconds before the real STS expiry
min_lifetime=3600 # re-mint once the cached session has less than this much life left

kc_service="aws-credential-process"
kc_account="$mfa_serial"

# Reuse the cached session only while it still has at least min_lifetime of life.
# The payload embeds our own not_after epoch alongside the STS JSON, so we compare
# against that rather than parsing the ISO-8601 Expiration in shell. A missing item
# (rc 44) or a corrupt payload (jq parse fails) simply falls through to a fresh mint.
cached="$(security find-generic-password -a "$kc_account" -s "$kc_service" -w 2>/dev/null || true)"
if [ -n "$cached" ]; then
  not_after="$(printf '%s' "$cached" | jq -r '.not_after // 0' 2>/dev/null || echo 0)"
  if [ "$(($(date +%s) + min_lifetime))" -lt "${not_after:-0}" ] 2>/dev/null; then
    printf '%s' "$cached" | jq -c '.creds'
    exit 0
  fi
fi

access_key_id="$(op read "${op_item}/Access Key")"
secret_access_key="$(op read "${op_item}/Secret Access Key")"
token_code="$(op item get --vault Private u3dlfqopqvanpp7vy3gai2sy4y --otp)"

# Pass the long-term key via env vars; aws-cli's env provider takes precedence
# over credential_process, so this sts call does not recurse back into this script.
creds="$(AWS_ACCESS_KEY_ID="$access_key_id" \
  AWS_SECRET_ACCESS_KEY="$secret_access_key" \
  aws sts get-session-token \
  --serial-number "$mfa_serial" \
  --token-code "$token_code" \
  --duration-seconds "$duration" \
  --query Credentials \
  --output json |
  jq '{Version: 1, AccessKeyId, SecretAccessKey, SessionToken, Expiration}')"

# Cache to the login keychain. -U replaces any prior item; -T scopes the ACL to
# /usr/bin/security so future reads don't prompt. (The secret transits argv here
# for the once-per-session mint — acceptable for a same-user temporary session.)
payload="$(jq -nc --argjson c "$creds" --argjson na "$(($(date +%s) + duration - margin))" '{not_after: $na, creds: $c}')"
security add-generic-password -U -a "$kc_account" -s "$kc_service" -T /usr/bin/security -w "$payload"

printf '%s\n' "$creds"
