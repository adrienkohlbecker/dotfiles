# Ghostty configuration
# https://ghostty.org/docs/config

copy-on-select = true
# Meslo is derived from Menlo; the Nerd Font build adds glyphs for eza/yazi icons.
# "M" = medium line-gap (closest to Menlo), "Mono" keeps icons single-cell so
# column-aligned output (eza, ls) doesn't drift.
font-family = MesloLGM Nerd Font Mono
font-size = 12
maximize = true
minimum-contrast = 2
mouse-hide-while-typing = true
# bytes, not lines (default is 10MB); per-surface, allocated lazily
scrollback-limit = 100000000
shell-integration = zsh
shell-integration-features = cursor,sudo,title,ssh-env,ssh-terminfo,path
theme = dracula
keybind = global:super+alt+shift+ctrl+t=toggle_quick_terminal
