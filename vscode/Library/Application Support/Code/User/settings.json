{
    "gitProjectManager.baseProjectsFolders": [
        "~/Work",
    ],
    "workbench.startupEditor": "newUntitledFile",
    "gitProjectManager.openInNewWindow": true,
    "gitProjectManager.storeRepositoriesBetweenSessions": true,
    "files.trimTrailingWhitespace": true,
    "files.eol": "\n",
    "files.trimFinalNewlines": true,
    "workbench.editorAssociations": {
        "*.pdf": "default",
        "*.svg": "svgPreview.previewEditor",
        "*.tsv": "default"
    },
    "remote.SSH.remotePlatform": {
        "homelab": "linux"
    },
    "terminal.integrated.scrollback": 10000,
    "files.autoSave": "onFocusChange",
    "editor.tabSize": 2,
    "files.associations": {
        "*.h": "c",
        "*.s": "asm",
        "*.toml.j2": "toml",
        "*.xml.j2": "xml",
        "*.conf.j2": "properties",
        "*.yaml.j2": "yaml",
        "*.yml.j2": "yaml",
        "*.service.j2": "systemd-unit-file",
        "*.sh.j2": "shellscript",
        "stdout": "ansi"
    },
    "editor.accessibilitySupport": "off",
    "redhat.telemetry.enabled": false,
    "go.toolsManagement.autoUpdate": true,
    "[xml]": {
        "editor.defaultFormatter": "redhat.vscode-xml"
    },
    "files.insertFinalNewline": true,
    "[asm]": {
        "editor.rulers": [
            {
                "column": 18
            },
            {
                "column": 50
            },
            120
        ]
    },
    "extensions.ignoreRecommendations": true,
    "convertToAsciiArt.favoriteFont": "ANSI Shadow",
    "git.terminalAuthentication": false,
    "editor.cursorBlinking": "phase",
    "window.commandCenter": false,
    "workbench.editor.tabSizing": "shrink",
    "editor.cursorSmoothCaretAnimation": "on",
    "workbench.tree.indent": 11,
    "workbench.tree.renderIndentGuides": "always",
    "workbench.tree.enableStickyScroll": true,
    "editor.formatOnSaveMode": "modificationsIfAvailable",
    "git.autofetch": true,
    "workbench.colorTheme": "Dracula Theme",
    "workbench.iconTheme": "material-icon-theme",
    "ansible.ansible.useFullyQualifiedCollectionNames": false,
    "yaml.customTags": [
        "!vault scalar"
    ],
    "update.showReleaseNotes": false,
    "terraform.experimentalFeatures.validateOnSave": true,
    "python.createEnvironment.trigger": "off",
    "shellformat.effectLanguages": [
        "shellscript",
        "dotenv",
        "hosts",
        "jvmoptions",
        "ignore",
        "gitignore",
        "properties",
        "spring-boot-properties",
        "azcli",
        "bats"
    ],
    "terraform.experimentalFeatures.prefillRequiredFields": true,
    "git.blame.editorDecoration.enabled": false,
    "ansible.lightspeed.enabled": false,
    "diffEditor.hideUnchangedRegions.enabled": true,
    "[dockercompose]": {
        "editor.defaultFormatter": "redhat.vscode-yaml"
    },
    "[github-actions-workflow]": {
        "editor.defaultFormatter": "redhat.vscode-yaml"
    },
    "[tsv]": {
        "editor.insertSpaces": false,
        "editor.detectIndentation": false,
    },
    "git.blame.statusBarItem.enabled": true,
    "python.analysis.typeCheckingMode": "standard",
    "[python]": {
        "editor.defaultFormatter": "ms-python.black-formatter",
        "diffEditor.ignoreTrimWhitespace": true,
        "editor.codeActionsOnSave": {
            "source.organizeImports.python": "explicit"
        }
    },
    "python.analysis.diagnosticMode": "workspace",
    "python.analysis.languageServerMode": "full",
    "python.analysis.regenerateStdLibIndices": true,
    "python.analysis.showOnlyDirectDependenciesInAutoImport": true,
    "python.analysis.typeEvaluation.strictDictionaryInference": true,
    "python.analysis.typeEvaluation.strictListInference": true,
    "python.analysis.typeEvaluation.strictSetInference": true,
    "python.analysis.autoFormatStrings": true,
    "python.analysis.autoImportCompletions": true,
    "black-formatter.args": [
        "-l",
        "250"
    ],
    "remote.autoForwardPorts": false,
    "python-envs.terminal.autoActivationType": "off",
    "editor.formatOnSave": true,
    "terminal.integrated.initialHint": false,
    "window.confirmSaveUntitledWorkspace": false,
    "window.confirmBeforeClose": "keyboardOnly",
    "claudeCode.useTerminal": true,
    "terminal.integrated.confirmOnExit": "hasChildProcesses",
    "terminal.integrated.enableVisualBell": true,
    "terminal.integrated.macOptionClickForcesSelection": true,
    "editor.fontFamily": "MesloLGM Nerd Font Mono",
    "terminal.integrated.fontFamily": "MesloLGM Nerd Font Mono",
    "chat.disableAIFeatures": true,
    "editor.guides.bracketPairs": "active",
    "scm.defaultViewMode": "tree",
    "files.watcherExclude": {
        "**/.terraform/**": true,
        "**/.venv/**": true,
        "**/node_modules/**": true
    },
    "search.exclude": {
        "**/.terraform/**": true,
        "**/.venv/**": true
    }
}
