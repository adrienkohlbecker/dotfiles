#!/usr/bin/env bash
set -euo pipefail

# Refuse to draft a message when nothing is staged — avoids an empty AI commit
# (tig binds this in both status and stage views, where staging may be empty).
if git diff --staged --quiet; then
  echo "git-ai-commit: nothing staged" >&2
  exit 1
fi

# Draft a commit message from the staged changes with claude (haiku) and open it
# in $EDITOR for review before committing. Bound to "E" in tig (status + stage views).
#
# The staged diff and recent log are computed here and piped to claude on stdin,
# rather than letting claude shell out to git itself: this keeps the draft scoped
# to the exact staged changes this script commits (one process, one cwd — tig may
# launch us from a subdirectory) and avoids a tool-permission prompt stalling
# inside the tig keybind.
context=$(
  printf '=== staged changes (git diff --staged) ===\n'
  git diff --staged
  printf '\n=== recent commit subjects (git log --oneline -15) ===\n'
  git log --oneline -15
)

msg=$(printf '%s\n' "$context" | claude --print --model haiku --no-session-persistence 'A git diff of staged changes followed by recent commit subjects is provided on stdin. Write a commit message for those staged changes.

Match the repository'\''s existing subject style and any role/scope prefix convention visible in the recent subjects.

Rules:
- Subject: imperative mood, capitalized, no trailing period, ~50 chars (72 hard max), naming what changed.
- For non-trivial changes add a blank line then a body wrapped at 72 columns explaining the what and, more importantly, the why/motivation and any context a reviewer needs. Prefer prose; use a bullet list only when there are several independent changes. Omit the body entirely for trivial changes.
- Do not mention Claude, AI, or that the message was generated.

Output only the raw commit message as plain text: no surrounding quotes, no code fences, no commentary.')

if [ -z "${msg//[[:space:]]/}" ]; then
  echo "git-ai-commit: claude returned an empty draft" >&2
  exit 1
fi

# Open the draft in $EDITOR for review (signing follows the repo's commit.gpgsign
# config). Clearing the buffer to bail makes git exit non-zero with no commit —
# treat that as a clean cancel rather than letting set -e report a script failure.
if ! printf '%s\n' "$msg" | git commit --file=- --edit; then
  echo "git-ai-commit: aborted (empty message)" >&2
  exit 0
fi
