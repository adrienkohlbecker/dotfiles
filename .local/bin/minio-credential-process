#!/usr/bin/env bash
set -euo pipefail

# credential_process for the MinIO s3 backend that holds the homelab tofu state
# (bucket "terraform" on minio-api.lab.fahm.fr). MinIO uses static keys (no STS),
# so emit the long-term key from 1Password as a Version-1 envelope.
#
# Used via [profile minio] in ~/.aws/config. Keeping these out of the AWS_* env
# vars leaves the default credential chain free for a real aws provider.
#
# Assign to locals first so a failed/locked `op` trips set -e — an inline
# "$(op read)" inside jq --arg does NOT, and would emit a valid-looking envelope
# with empty keys (opaque S3 403 downstream).
id="$(op read 'op://Lab/iiis755ps5mhhlpmcv25lrctgu/username')"
secret="$(op read 'op://Lab/iiis755ps5mhhlpmcv25lrctgu/password')"
[ -n "$id" ] && [ -n "$secret" ] || { echo "minio-credential-process: empty credential from 1Password" >&2; exit 1; }

jq -n --arg id "$id" --arg secret "$secret" \
  '{Version: 1, AccessKeyId: $id, SecretAccessKey: $secret}'
