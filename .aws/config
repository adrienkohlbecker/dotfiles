[default]
output=json
region=eu-central-1
credential_process=aws-credential-process

[profile minio]
# Static MinIO keys (op-sourced) for the homelab tofu s3 backend; see
# ~/.local/bin/minio-credential-process. Kept off AWS_* env vars so they don't
# collide with the default profile or a real aws provider.
credential_process=minio-credential-process
