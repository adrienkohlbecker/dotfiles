[alias]
  # Simple shortcut
  ci = commit
  co = checkout
  br = branch
  st = status
  ts = status
  pr = pull-request
  cp = cherry-pick
  # merge without fast forward
  noff = merge --no-ff
  # delete branches already merged into the default branch (true merges only;
  # squash-merged branches leave no merge commit — use clean_gone for those).
  # dfb resolved once so the network self-heal in dfb doesn't run three times.
  roomba = "!b=$(git dfb); git checkout -q \"$b\" && { git pull --ff-only || true; } && git branch --merged \"$b\" --format='%(refname:short)' | grep -vx \"$b\" | xargs -r -I{} git branch -d -- {}"
  # get default branch bare name (e.g. "master"); self-heal a missing origin/HEAD,
  # falling back to init.defaultBranch when there is no origin at all (so a
  # local-only repo yields "master" instead of a bogus "HEAD" + stderr noise)
  dfb = "!git symbolic-ref -q refs/remotes/origin/HEAD >/dev/null 2>&1 || git remote set-head origin --auto >/dev/null 2>&1 || true; b=$(git rev-parse --abbrev-ref origin/HEAD 2>/dev/null | cut -d/ -f2-); { [ -n \"$b\" ] && [ \"$b\" != HEAD ] && echo \"$b\"; } || git config init.defaultBranch"
  # most-recently-committed local branches (author shown, not filtered)
  recent-branches = "!git for-each-ref --color=auto --sort=-committerdate --count=10 --format='%(color:bold yellow)%(refname:short)%(color:reset) (%(color:bold magenta)%(committerdate:relative)%(color:reset)) %(color:cyan)%(objectname:short)%(color:reset) %(color:dim white)%(authorname)%(color:reset) - %(contents:subject)' refs/heads/"

[core]
  # Use custom `.gitignore`
	excludesfile = ~/.gitignore
	# Cache untracked-file scan results (no daemon; safe even for the $HOME-work-tree
	# dotfiles repo). core.fsmonitor deliberately NOT set globally: its daemon would
	# try to watch all of $HOME via the dotfiles bare repo. Enable per-repo if wanted.
	untrackedCache = true
[index]
	# Skip the index trailing checksum — cheaper add/commit/status on the large
	# $HOME-work-tree index. Honored on git >= 2.40; silently ignored on older.
	skipHash = true
[column]
  ui = auto
[fetch]
  prune = true
  pruneTags = true
  all = true
[push]
  autoSetupRemote = true
  followTags = true
  # --force-with-lease also refuses if there are remote commits we never fetched
  useForceIfIncludes = true
[transfer]
  # Verify object integrity on fetch/receive (catches corrupt/malicious objects)
  fsckObjects = true
[pull]
  rebase = true
[credential]
  helper = osxkeychain
[help]
  autocorrect = prompt
[diff]
  algorithm = histogram
  colorMoved = zebra
  colorMovedWS = allow-indentation-change
  mnemonicPrefix = true
[commit]
	gpgsign = true
  verbose = true
[gpg]
	program = gpg
	format = ssh
[user]
	name = Adrien Kohlbecker
	email = adrien.kohlbecker@gmail.com
	signingkey = ~/.ssh/id_ed25519.pub
[init]
	defaultBranch = master
[merge]
  log = true
  # diff3 (not zdiff3): zdiff3 needs git >= 2.35, Ubuntu jammy ships 2.34
  conflictstyle = diff3
[rebase]
  autoSquash = true
  autoStash = true
  updateRefs = true
  missingCommitsCheck = warn
[branch]
  sort = -committerdate
[tag]
  sort = version:refname
[rerere]
  enabled = true
  autoupdate = true
[gpg "ssh"]
	allowedSignersFile = ~/.ssh/allowed_signers
[include]
  path = ~/.gitconfig.local
# Per-tree identity override (uncomment + create the file to use a work email
# under ~/Work/, etc.):
# [includeIf "gitdir:~/Work/"]
#   path = ~/.gitconfig.work
