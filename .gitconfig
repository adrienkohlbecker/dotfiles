[alias]
  # Simple shortcut
  ci = commit
  co = checkout
  br = branch
  st = status
  ts = status
  pr = pull-request
  cp = cherry-pick
  # merge without fast forward
  noff = merge --no-ff
  # delete branches already merged into the default branch
  roomba = "!git checkout -q \"$(git dfb)\" && git pull && git branch --merged \"$(git dfb)\" --format='%(refname:short)' | grep -vx \"$(git dfb)\" | xargs -r -I{} git branch -d -- {}"
  # get default branch (bare name, e.g. "master"); self-heal a missing origin/HEAD
  dfb = "!git symbolic-ref -q refs/remotes/origin/HEAD >/dev/null 2>&1 || git remote set-head origin --auto >/dev/null 2>&1; git rev-parse --abbrev-ref origin/HEAD | cut -d/ -f2-"
	recent-branches = ! git for-each-ref --sort=-committerdate --format='%(authorname),%(color:bold yellow)%(refname:short)%(color:reset) (%(color:bold magenta)%(committerdate:relative)%(color:reset)) %(color:cyan)%(objectname:short)%(color:reset) - %(color:dim white)%(contents:subject)%(color:reset)' --color=always refs/heads/ | grep Kohlbecker | cut -d, -f2 | head -n10

[core]
  # Use custom `.gitignore` and `.gitattributes`
	excludesfile = ~/.gitignore
	attributesfile = ~/.gitattributes
	# Cache untracked-file scan results (no daemon; safe even for the $HOME-work-tree
	# dotfiles repo). core.fsmonitor deliberately NOT set globally: its daemon would
	# try to watch all of $HOME via the dotfiles bare repo. Enable per-repo if wanted.
	untrackedCache = true
[column]
  ui = auto
[fetch]
  prune = true
  pruneTags = true
  all = true
[push]
  default = simple
  autoSetupRemote = true
  followTags = true
  # --force-with-lease also refuses if there are remote commits we never fetched
  useForceIfIncludes = true
[transfer]
  # Verify object integrity on fetch/receive (catches corrupt/malicious objects)
  fsckObjects = true
[pull]
  rebase = true
[credential]
  helper = osxkeychain
[help]
  autocorrect = prompt
[diff]
  algorithm = histogram
  colorMoved = plain
  mnemonicPrefix = true
  renames = true
[commit]
	gpgsign = true
  verbose = true
[gpg]
	program = gpg
	format = ssh
[user]
	name = Adrien Kohlbecker
	email = adrien.kohlbecker@gmail.com
	signingkey = ~/.ssh/id_ed25519.pub
[init]
	defaultBranch = master
[merge]
  log = true
  conflictstyle = zdiff3
[rebase]
  autoSquash = true
  autoStash = true
  updateRefs = true
[branch]
  sort = -committerdate
[tag]
  sort = version:refname
[rerere]
  enabled = true
  autoupdate = true
[gpg "ssh"]
	allowedSignersFile = ~/.ssh/allowed_signers
[include]
  path = ~/.gitconfig.local
