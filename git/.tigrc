# Interactive rebase
bind main B !git rebase -i %(commit)
bind main ! !git revert %(commit)

# Ammend commit
bind status + !git commit --amend
bind status P !gh pr create --web
bind status L !glab mr create --remove-source-branch

# discard file changes (confirm first — irreversible for unstaged work)
bind status X ?@git checkout -- %(file)
bind stage  X ?@git checkout -- %(file)

# remove file (confirm first — irreversible for untracked files)
bind status <Delete> ?@rm %(file)
bind stage <Delete> ?@rm %(file)

# open file diff in delta (syntax-highlighted)
bind status D !sh -c "git diff HEAD -- %(file) | delta --paging=always"
bind stage  D !sh -c "git diff HEAD -- %(file) | delta --paging=always"

bind status = !git roomba
bind status B !git rebase --continue
bind status E !git-ai-commit

bind stage + !git commit --amend
bind stage C !git commit
bind stage E !git-ai-commit

bind stage B !git rebase --continue

bind refs M !git merge --no-ff %(branch)
bind refs B @git branch %(prompt) %(branch)

bind refs C ?@git checkout %(branch)

# copy commit hash to clipboard
bind main  Y @sh -c "echo -n %(commit) | pbcopy"
bind diff  Y @sh -c "echo -n %(commit) | pbcopy"
bind log   Y @sh -c "echo -n %(commit) | pbcopy"
bind blame Y @sh -c "echo -n %(commit) | pbcopy"

# open file in editor
bind status V !$EDITOR %(file)
bind stage  V !$EDITOR %(file)
bind blame  V !$EDITOR +%(lineno) %(file)

# open current commit in delta (syntax-highlighted diff)
bind main  D !sh -c "git show %(commit) | delta --paging=always"
bind diff  D !sh -c "git show %(commit) | delta --paging=always"
bind log   D !sh -c "git show %(commit) | delta --paging=always"
bind blame D !sh -c "git show %(commit) | delta --paging=always"

bind generic S !git push %(branch)
bind status S !git push

# force-push: confirm first, and only from refs (selected branch) or status
# (current branch) — not every view, since it rewrites remote history
bind refs F ?!git push --force-with-lease -u origin %(branch)
bind status F ?!git push --force-with-lease -u origin

# don't show contents of untracked directories
set status-show-untracked-dirs = false

# distinguish ref types in the views: [branch] <tag> {remote}
set reference-format = "[branch] <tag> {remote}"
# wrap long lines (e.g. commit subjects) instead of truncating them
set wrap-lines = true
# enable mouse scroll / selection
set mouse = true
# word-level emphasis in diffs via a ~/.local/bin wrapper that probes known
# contrib paths and falls back to cat where diff-highlight isn't installed.
set diff-highlight = true
